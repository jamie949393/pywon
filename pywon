#!/bin/sh
# .pywon interpreter
# Usage: ./pywon script.pywon

if [ $# -eq 0 ]; then
    echo "Usage: $0 <file.pywon>"
    exit 1
fi

if [ ! -f "$1" ]; then
    echo "Error: File '$1' not found"
    exit 1
fi

# Helper function to get value (variable or literal number/string)
get_value() {
    val="$1"
    has_dollar=0
    
    # Check if it starts with $
    case "$val" in
        \$*)
            has_dollar=1
            val="${val#\$}"
            ;;
    esac
    
    # Check if it's a number
    case "$val" in
        ''|*[!0-9.-]*)
            # Not a number
            if [ $has_dollar -eq 1 ]; then
                # Has $, so it's definitely a variable
                eval "echo \"\$$val\""
            else
                # No $, check if variable exists
                eval "test -n \"\${$val+x}\"" 2>/dev/null
                if [ $? -eq 0 ]; then
                    # Variable exists, return its value
                    eval "echo \"\$$val\""
                else
                    # Variable doesn't exist, treat as literal string
                    echo "$val"
                fi
            fi
            ;;
        *)
            # It's a number, return as-is
            echo "$val"
            ;;
    esac
}

# Function to check if value is a number
is_number() {
    case "$1" in
        ''|*[!0-9.-]*) return 1 ;;
        *) return 0 ;;
    esac
}

# Function to evaluate condition
eval_condition() {
    condition="$1"
    # Parse: $var >5 or $var < $other or var =5
    left=$(echo "$condition" | sed 's/[<>=].*//' | sed 's/ *$//')
    operator=$(echo "$condition" | sed 's/.*\([<>=]\).*/\1/')
    right=$(echo "$condition" | sed 's/.*[<>=]//' | sed 's/^ *//')
    
    # Get actual values
    left_val=$(get_value "$left")
    right_val=$(get_value "$right")
    
    # Check if both values are numbers
    if is_number "$left_val" && is_number "$right_val"; then
        # Numeric comparison
        case "$operator" in
            ">")
                [ "$left_val" -gt "$right_val" ] 2>/dev/null && return 0 || return 1
                ;;
            "<")
                [ "$left_val" -lt "$right_val" ] 2>/dev/null && return 0 || return 1
                ;;
            "=")
                [ "$left_val" = "$right_val" ] && return 0 || return 1
                ;;
            *)
                return 1
                ;;
        esac
    else
        # String comparison - only = is allowed
        case "$operator" in
            "=")
                [ "$left_val" = "$right_val" ] && return 0 || return 1
                ;;
            ">"|"<")
                echo "Error: Cannot use > or < with strings (comparing '$left_val' and '$right_val')" >&2
                return 1
                ;;
            *)
                return 1
                ;;
        esac
    fi
}

# Function to execute a single line
execute_line() {
    line="$1"
    
    # Skip empty lines and comments
    case "$line" in
        ""|\#*)
            return
            ;;
    esac
    
    # Check command type
    case "$line" in
        print*)
            # Extract everything after "print "
            text="${line#print }"
            # Expand variables in the text
            eval "echo \"$text\""
            ;;
        input*)
            # Extract variable name after "input "
            varname="${line#input }"
            varname=$(echo "$varname" | tr -d ' ')
            # Read input from user (redirect from terminal)
            read -r user_input </dev/tty 2>/dev/null || read -r user_input
            # Store in the variable with the specified name
            eval "$varname='$user_input'"
            ;;
        set*)
            # Extract variable name and value after "set "
            rest="${line#set }"
            # Get first word as variable name
            varname=$(echo "$rest" | awk '{print $1}')
            # Get everything after first word as value
            value=$(echo "$rest" | cut -d' ' -f2-)
            # Expand any variables in the value
            eval "value=\"$value\""
            # Store in the variable
            eval "$varname='$value'"
            ;;
        add*)
            # Parse: add num1 num2 = result
            rest="${line#add }"
            # Split by '='
            left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
            result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
            # Get the two operands
            var1=$(echo "$left" | awk '{print $1}')
            var2=$(echo "$left" | awk '{print $2}')
            # Get values (variable or literal)
            num1=$(get_value "$var1")
            num2=$(get_value "$var2")
            # Calculate
            result=$((num1 + num2))
            # Store result
            eval "$result_var='$result'"
            ;;
        sub*)
            # Parse: sub num1 num2 = result
            rest="${line#sub }"
            left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
            result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
            var1=$(echo "$left" | awk '{print $1}')
            var2=$(echo "$left" | awk '{print $2}')
            num1=$(get_value "$var1")
            num2=$(get_value "$var2")
            result=$((num1 - num2))
            eval "$result_var='$result'"
            ;;
        multi*)
            # Parse: multi num1 num2 = result
            rest="${line#multi }"
            left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
            result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
            var1=$(echo "$left" | awk '{print $1}')
            var2=$(echo "$left" | awk '{print $2}')
            num1=$(get_value "$var1")
            num2=$(get_value "$var2")
            result=$((num1 * num2))
            eval "$result_var='$result'"
            ;;
        divi*)
            # Parse: divi num1 num2 = result
            rest="${line#divi }"
            left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
            result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
            var1=$(echo "$left" | awk '{print $1}')
            var2=$(echo "$left" | awk '{print $2}')
            num1=$(get_value "$var1")
            num2=$(get_value "$var2")
            # Check for division by zero
            if [ "$num2" = "0" ]; then
                result=0
            else
                # Use awk for decimal division
                result=$(awk "BEGIN {printf \"%.2f\", $num1 / $num2}")
            fi
            eval "$result_var='$result'"
            ;;
    esac
}

# Read entire file into array-like structure using a temp file
tmpfile="/tmp/pywon_$$"
cat "$1" > "$tmpfile"

# Process file
line_num=0
total_lines=$(wc -l < "$tmpfile")

while [ $line_num -lt $total_lines ]; do
    line_num=$((line_num + 1))
    line=$(sed -n "${line_num}p" "$tmpfile")
    
    # Check for loop start
    if echo "$line" | grep -q "^loop "; then
        # Extract number: "loop 5 times" -> 5
        loop_count=$(echo "$line" | awk '{print $2}')
        
        # Find loop body (lines between "loop" and "loop close")
        loop_start=$((line_num + 1))
        loop_end=$line_num
        
        # Find "loop close"
        search_line=$((line_num + 1))
        while [ $search_line -le $total_lines ]; do
            check_line=$(sed -n "${search_line}p" "$tmpfile")
            if echo "$check_line" | grep -q "^loop close"; then
                loop_end=$((search_line - 1))
                break
            fi
            search_line=$((search_line + 1))
        done
        
        # Execute loop body loop_count times
        i=1
        while [ $i -le $loop_count ]; do
            body_line=$loop_start
            while [ $body_line -le $loop_end ]; do
                body_content=$(sed -n "${body_line}p" "$tmpfile")
                execute_line "$body_content"
                body_line=$((body_line + 1))
            done
            i=$((i + 1))
        done
        
        # Skip to after "loop close"
        line_num=$((search_line))
        continue
    fi
    
    # Check for if statement
    if echo "$line" | grep -q "^if "; then
        # Extract condition: "if $num >5" -> "$num >5"
        condition="${line#if }"
        
        # Evaluate condition
        if eval_condition "$condition"; then
            condition_met=1
        else
            condition_met=0
        fi
        
        # Find the if block (until else or end)
        if_start=$((line_num + 1))
        if_end=$line_num
        else_start=0
        else_end=0
        
        # Find else or end
        search_line=$((line_num + 1))
        depth=0
        while [ $search_line -le $total_lines ]; do
            check_line=$(sed -n "${search_line}p" "$tmpfile")
            
            # Track nested ifs
            if echo "$check_line" | grep -q "^if "; then
                depth=$((depth + 1))
            fi
            
            if [ $depth -eq 0 ]; then
                if echo "$check_line" | grep -q "^else"; then
                    if_end=$((search_line - 1))
                    else_start=$((search_line + 1))
                    search_line=$((search_line + 1))
                    continue
                fi
                
                if echo "$check_line" | grep -q "^end"; then
                    if [ $else_start -eq 0 ]; then
                        if_end=$((search_line - 1))
                    else
                        else_end=$((search_line - 1))
                    fi
                    break
                fi
            else
                if echo "$check_line" | grep -q "^end"; then
                    depth=$((depth - 1))
                fi
            fi
            
            search_line=$((search_line + 1))
        done
        
        # Execute appropriate block
        if [ $condition_met -eq 1 ]; then
            # Execute if block
            body_line=$if_start
            while [ $body_line -le $if_end ]; do
                body_content=$(sed -n "${body_line}p" "$tmpfile")
                execute_line "$body_content"
                body_line=$((body_line + 1))
            done
        else
            # Execute else block if it exists
            if [ $else_start -ne 0 ]; then
                body_line=$else_start
                while [ $body_line -le $else_end ]; do
                    body_content=$(sed -n "${body_line}p" "$tmpfile")
                    execute_line "$body_content"
                    body_line=$((body_line + 1))
                done
            fi
        fi
        
        # Skip to after "end"
        line_num=$((search_line))
        continue
    fi
    
    # Execute line if not a control structure keyword
    if ! echo "$line" | grep -qE "^(loop close|else|end)"; then
        execute_line "$line"
    fi
done

# Cleanup
rm -f "$tmpfile"
