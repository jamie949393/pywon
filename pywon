#!/bin/bash
# .pywon interpreter
# Usage: ./pywon script.pywon

if [ $# -eq 0 ]; then
    echo "Usage: $0 <file.pywon>"
    exit 1
fi

if [ ! -f "$1" ]; then
    echo "Error: File '$1' not found"
    exit 1
fi

# Read file into array
mapfile -t lines < "$1"
total_lines=${#lines[@]}

# Associative array for variables
declare -A vars

# Helper function to get value (variable or literal)
get_value() {
    local val="$1"
    
    # Remove $ prefix if present
    if [[ "$val" == \$* ]]; then
        val="${val:1}"
        echo "${vars[$val]}"
        return
    fi
    
    # Check if it's a number
    if [[ "$val" =~ ^-?[0-9]+\.?[0-9]*$ ]]; then
        echo "$val"
        return
    fi
    
    # Check if variable exists
    if [[ -v vars[$val] ]]; then
        echo "${vars[$val]}"
    else
        echo "$val"
    fi
}

is_number() {
    [[ "$1" =~ ^-?[0-9]+\.?[0-9]*$ ]]
}

eval_condition() {
    local condition="$1"
    local left operator right left_val right_val
    
    left=$(echo "$condition" | sed 's/[<>=].*//' | sed 's/ *$//')
    operator=$(echo "$condition" | sed 's/.*\([<>=]\).*/\1/')
    right=$(echo "$condition" | sed 's/.*[<>=]//' | sed 's/^ *//')
    
    left_val=$(get_value "$left")
    right_val=$(get_value "$right")
    
    if is_number "$left_val" && is_number "$right_val"; then
        case "$operator" in
            ">") (( left_val > right_val )) ;;
            "<") (( left_val < right_val )) ;;
            "=") [[ "$left_val" == "$right_val" ]] ;;
            *) return 1 ;;
        esac
    else
        case "$operator" in
            "=") [[ "$left_val" == "$right_val" ]] ;;
            ">"|"<") echo "Error: Cannot use > or < with strings" >&2; return 1 ;;
            *) return 1 ;;
        esac
    fi
}

# Find matching close for a block
find_close() {
    local start=$1 open_pat="$2" close_pat="$3"
    local search=$((start + 1)) depth=0
    
    while (( search < total_lines )); do
        local check="${lines[$search]}"
        # Skip "while close" when looking for nested "while "
        if [[ "$check" =~ ^$open_pat ]] && [[ "$check" != "$close_pat" ]]; then
            ((depth++))
        fi
        if [[ "$check" == "$close_pat" ]]; then
            (( depth == 0 )) && { echo $search; return; }
            ((depth--))
        fi
        ((search++))
    done
    echo $total_lines
}

# Find else for an if block
find_else() {
    local start=$1 end=$2
    local search=$((start + 1)) depth=0
    
    while (( search < end )); do
        local check="${lines[$search]}"
        [[ "$check" =~ ^if\  ]] && ((depth++))
        [[ "$check" == "end" ]] && ((depth--))
        if (( depth == 0 )) && [[ "$check" == "else" ]]; then
            echo $search
            return
        fi
        ((search++))
    done
    echo -1
}

# Execute code from line $1 to line $2
run_lines() {
    local run_start=$1 run_end=$2
    local cur=$run_start
    
    while (( cur <= run_end )); do
        local line="${lines[$cur]}"
        
        # Skip empty lines and comments
        [[ -z "$line" || "$line" == \#* ]] && { ((cur++)); continue; }
        
        # Handle while loop (but not "while close")
        if [[ "$line" =~ ^while\  ]] && [[ "$line" != "while close" ]]; then
            local condition="${line#while }"
            local close_line=$(find_close $cur "while " "while close")
            
            while eval_condition "$condition"; do
                run_lines $((cur + 1)) $((close_line - 1))
            done
            
            cur=$close_line
            ((cur++))
            continue
        fi
        
        # Handle loop N times (but not "loop close")
        if [[ "$line" =~ ^loop\ [0-9] ]] && [[ "$line" != "loop close" ]]; then
            local loop_count=$(echo "$line" | awk '{print $2}')
            local close_line=$(find_close $cur "loop [0-9]" "loop close")
            
            for ((i=1; i<=loop_count; i++)); do
                run_lines $((cur + 1)) $((close_line - 1))
            done
            
            cur=$close_line
            ((cur++))
            continue
        fi
        
        # Handle if statement
        if [[ "$line" =~ ^if\  ]]; then
            local condition="${line#if }"
            local end_line=$(find_close $cur "if " "end")
            local else_line=$(find_else $cur $end_line)
            
            if eval_condition "$condition"; then
                if (( else_line == -1 )); then
                    run_lines $((cur + 1)) $((end_line - 1))
                else
                    run_lines $((cur + 1)) $((else_line - 1))
                fi
            else
                if (( else_line != -1 )); then
                    run_lines $((else_line + 1)) $((end_line - 1))
                fi
            fi
            
            cur=$((end_line + 1))
            continue
        fi
        
        # Skip control keywords
        case "$line" in
            "loop close"|"while close"|"else"|"end")
                ((cur++))
                continue
                ;;
        esac
        
        # Execute simple commands
        case "$line" in
            print|print\ *)
                if [[ "$line" == "print" ]]; then
                    echo ""
                else
                    local text="${line#print }"
                    # Expand variables
                    while [[ "$text" =~ \$([a-zA-Z_][a-zA-Z0-9_]*) ]]; do
                        local vn="${BASH_REMATCH[1]}"
                        local vv="${vars[$vn]}"
                        text="${text//\$$vn/$vv}"
                    done
                    echo "$text"
                fi
                ;;
            input*)
                local varname="${line#input }"
                varname="${varname// /}"
                read -r vars[$varname] </dev/tty 2>/dev/null || read -r vars[$varname]
                ;;
            set*)
                local rest="${line#set }"
                local varname=$(echo "$rest" | awk '{print $1}')
                local value=$(echo "$rest" | cut -d' ' -f2-)
                # Expand variables in value
                while [[ "$value" =~ \$([a-zA-Z_][a-zA-Z0-9_]*) ]]; do
                    local vn="${BASH_REMATCH[1]}"
                    local vv="${vars[$vn]}"
                    value="${value//\$$vn/$vv}"
                done
                vars[$varname]="$value"
                ;;
            add*)
                local rest="${line#add }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local var1=$(echo "$left" | awk '{print $1}')
                local var2=$(echo "$left" | awk '{print $2}')
                local num1=$(get_value "$var1")
                local num2=$(get_value "$var2")
                vars[$result_var]=$((num1 + num2))
                ;;
            sub*)
                local rest="${line#sub }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local var1=$(echo "$left" | awk '{print $1}')
                local var2=$(echo "$left" | awk '{print $2}')
                local num1=$(get_value "$var1")
                local num2=$(get_value "$var2")
                vars[$result_var]=$((num1 - num2))
                ;;
            multi*)
                local rest="${line#multi }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local var1=$(echo "$left" | awk '{print $1}')
                local var2=$(echo "$left" | awk '{print $2}')
                local num1=$(get_value "$var1")
                local num2=$(get_value "$var2")
                vars[$result_var]=$((num1 * num2))
                ;;
            divi*)
                local rest="${line#divi }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local var1=$(echo "$left" | awk '{print $1}')
                local var2=$(echo "$left" | awk '{print $2}')
                local num1=$(get_value "$var1")
                local num2=$(get_value "$var2")
                if [[ "$num2" == "0" ]]; then
                    vars[$result_var]=0
                else
                    vars[$result_var]=$(awk "BEGIN {printf \"%.2f\", $num1 / $num2}")
                fi
                ;;
            mod*)
                local rest="${line#mod }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local var1=$(echo "$left" | awk '{print $1}')
                local var2=$(echo "$left" | awk '{print $2}')
                local num1=$(get_value "$var1")
                local num2=$(get_value "$var2")
                vars[$result_var]=$((num1 % num2))
                ;;
            clear)
                printf '\033[2J\033[H'
                ;;
            wait*)
                local ms="${line#wait }"
                ms=$(get_value "$ms")
                local seconds=$(awk "BEGIN {printf \"%.3f\", $ms / 1000}")
                sleep "$seconds"
                ;;
            random*)
                local rest="${line#random }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local min=$(echo "$left" | awk '{print $1}')
                local max=$(echo "$left" | awk '{print $2}')
                min=$(get_value "$min")
                max=$(get_value "$max")
                local range=$((max - min + 1))
                vars[$result_var]=$((min + (RANDOM % range)))
                ;;
            key*)
                local result_var="${line#key = }"
                result_var="${result_var// /}"
                local key_pressed=""
                if command -v stty >/dev/null 2>&1; then
                    local old_settings=$(stty -g </dev/tty 2>/dev/null)
                    stty -icanon -echo min 0 time 1 </dev/tty 2>/dev/null
                    key_pressed=$(dd bs=1 count=1 </dev/tty 2>/dev/null)
                    stty "$old_settings" </dev/tty 2>/dev/null
                fi
                vars[$result_var]="$key_pressed"
                ;;
            list*)
                local rest="${line#list }"
                local listname=$(echo "$rest" | awk '{print $1}')
                local size=$(echo "$rest" | awk '{print $2}')
                local default=$(echo "$rest" | awk '{print $3}')
                size=$(get_value "$size")
                [[ -z "$default" ]] && default=0
                default=$(get_value "$default")
                vars["${listname}_size"]=$size
                for ((i=0; i<size; i++)); do
                    vars["${listname}_${i}"]=$default
                done
                ;;
            get*)
                local rest="${line#get }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local listname=$(echo "$left" | awk '{print $1}')
                local index=$(echo "$left" | awk '{print $2}')
                index=$(get_value "$index")
                vars[$result_var]="${vars[${listname}_${index}]}"
                ;;
            put*)
                local rest="${line#put }"
                local listname=$(echo "$rest" | awk '{print $1}')
                local index=$(echo "$rest" | awk '{print $2}')
                local value=$(echo "$rest" | awk '{print $3}')
                index=$(get_value "$index")
                value=$(get_value "$value")
                vars["${listname}_${index}"]="$value"
                ;;
            len*)
                local rest="${line#len }"
                local left=$(echo "$rest" | cut -d'=' -f1 | sed 's/ *$//')
                local result_var=$(echo "$rest" | cut -d'=' -f2 | sed 's/^ *//')
                local listname=$(echo "$left" | awk '{print $1}')
                vars[$result_var]="${vars[${listname}_size]}"
                ;;
        esac
        
        ((cur++))
    done
}

# Run the entire program
run_lines 0 $((total_lines - 1))
